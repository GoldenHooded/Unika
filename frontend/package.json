{
  "name": "unika",
  "version": "1.0.0",
  "description": "Unika — Unity AI Agent",
  "main": "out/main/index.js",
  "author": "Unika",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "electron:dev": "electron-vite dev",
    "dist": "electron-vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.unika.app",
    "productName": "Unika",
    "icon": "public/icon",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "public"
    },
    "files": [
      "out/**/*",
      "public/icon.png",
      "public/icon.ico",
      "public/unika-logo.png",
      "public/unika-logo.svg",
      "public/sounds/**"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/unika-agent/",
        "to": "unika-agent/"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    }
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.26.3",
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@uiw/codemirror-extensions-langs": "^4.23.0",
    "@uiw/react-codemirror": "^4.23.0",
    "codemirror": "^6.0.1",
    "katex": "^0.16.11",
    "lucide-react": "^0.477.0",
    "marked": "^13.0.0",
    "marked-katex-extension": "^5.1.7",
    "mermaid": "^11.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/katex": "^0.16.7",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
